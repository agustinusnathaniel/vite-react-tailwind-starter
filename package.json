{
  "name": "vite-react-tailwind",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.11.x"
  },
  "packageManager": "pnpm@11.7.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.16.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "vp dev --port 3000",
    "start": "vp dev --port 3000",
    "build": "vp build",
    "serve": "vp preview",
    "generate-pwa-assets": "pwa-assets-generator",
    "turbo": "pnpm dlx turbo@2.6.1",
    "type:check": "tsc",
    "test": "vp test run",
    "test:ui": "vp test --ui --coverage",
    "test:coverage": "vp test --coverage run",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "biome:ci": "biome ci",
    "check:turbo": "pnpm turbo ultracite:check type:check test",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "validate:csp": "node --experimental-strip-types scripts/validate-csp.ts",
    "knip": "knip",
    "prepare": "vp config"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.11",
    "@theme-toggles/react": "^4.1.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@julr/vite-plugin-validate-env": "^2.2.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "commit-and-tag-version": "^12.7.3",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "typescript": "^6.0.3",
    "ultracite": "7.3.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.22",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.22",
    "web-vitals": "^5.2.0"
  }
}
